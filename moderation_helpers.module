<?php

declare(strict_types=1);

use Drupal\Core\Entity\EntityInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_preprocess_toolbar().
 */
function moderation_helpers_preprocess_toolbar(&$variables): void {
  if (!function_exists('_gin_toolbar_gin_is_active') || !_gin_toolbar_gin_is_active()) {
    return;
  }
  preg_match(
    '#entity\.(?<entity_type_id>.+)\.(?<page_type>[\w_]+)#',
    $variables['route_name'], $matches
  );
  if (isset($matches['entity_type_id']) && $matches['entity_type_id'] === 'node') {
    /** @var \Drupal\node\NodeInterface|null $entity */
    $entity = \Drupal::request()->attributes->get('node');
    /** @var \Drupal\node\NodeInterface|null $rev */
    $rev = \Drupal::request()->attributes->get('node_revision');

    $variables['moderation_form'] = \Drupal::formBuilder()->getForm(
      'Drupal\moderation_helpers\Form\ModerationHelperForm',
      ['node' => $entity, 'rev' => $rev]
    );
  }
}

/**
 * Implements hook_theme_suggestions_toolbar_alter().
 */
function moderation_helpers_theme_suggestions_toolbar_alter(array &$suggestions, array $variables): void {
  if (function_exists('_gin_toolbar_gin_is_active') && _gin_toolbar_gin_is_active()) {
    $suggestions[] = 'toolbar__moderation_helpers';
  }
}

/**
 * Implements hook_theme().
 */
function moderation_helpers_theme($existing, $type, $theme, $path): array {
  return [
    'toolbar__moderation_helpers' => [
      'base hook' => 'toolbar',
    ],
    'moderation_helper_form' => [
      'render element' => 'form',
    ],
    'moderation_helper_buttons' => [
      'variables' => [
        'edit' => NULL,
        'history' => NULL,
      ],
    ],
    'moderation_helper_state' => [
      'variables' => [
        'message' => NULL,
        'time_label' => NULL,
        'time' => NULL,
        'author_label' => NULL,
        'author' => NULL,
        'bottom' => NULL,
        'state_class' => NULL,
      ],
    ],
  ];
}

/**
 * Prepares variables for the moderation helper form template.
 */
function template_preprocess_moderation_helper_form(&$variables): void {
  $variables['is_latest'] = $variables['form']['#is_latest'] ?? FALSE;
}

/**
 * Implements hook_node_presave().
 *
 * When reverting to an old revision, copy the revision log message from the
 * source revision so it carries forward into the new revision.
 */
function moderation_helpers_node_presave(EntityInterface $entity): void {
  if (!$entity instanceof NodeInterface || !$entity->isNewRevision()) {
    return;
  }

  $param = \Drupal::routeMatch()->getParameter('node_revision');

  if (!$param instanceof NodeInterface) {
    return;
  }

  $rev = $param->getLoadedRevisionId();
  $revision = \Drupal::entityTypeManager()
    ->getStorage('node')
    ->loadRevision($rev);

  $message = $revision->getRevisionLogMessage();
  if (is_string($message)
    && !empty($message)
    && !str_ends_with($message, 'from moderation toolbar.')
  ) {
    $entity->setRevisionLogMessage($message);
  }
}
